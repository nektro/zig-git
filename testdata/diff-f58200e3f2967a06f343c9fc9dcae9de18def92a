+pub const Symbol = struct {
+    ni: MappedFile.Node.Index,
+    /// Relocations contained within this symbol
+    loc_relocs: Reloc.Index,
+    /// Relocations targeting this symbol
+    target_relocs: Reloc.Index,
+    unused: u32 = 0,
