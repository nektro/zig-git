+                reloc.apply(elf);
+            }
+        }
+
+        pub fn applyTargetRelocs(si: Symbol.Index, elf: *Elf) void {
+            var ri = si.get(elf).target_relocs;
+            while (ri != .none) {
+                const reloc = ri.get(elf);
+                assert(reloc.target == si);
+                reloc.apply(elf);
+                ri = reloc.next;
+            }
+        }
+
