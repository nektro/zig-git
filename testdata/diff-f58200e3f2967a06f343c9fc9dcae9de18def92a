+                if (reloc.loc != si) break;
+                reloc.delete(elf);
+            }
+            sym.loc_relocs = .none;
+        }
+    };
+
+    comptime {
+        if (!std.debug.runtime_safety) std.debug.assert(@sizeOf(Symbol) == 16);
+    }
